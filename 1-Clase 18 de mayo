float posX, posY;     
float velocidadX, velocidadY; 
float distanciaX, distanciaY;
float divisor;          
float diametroPelota;  

void setup() {
  size(800, 800);      
  posX = width / 2;
  posY = height / 2;
  
  divisor = 50;        
  diametroPelota = 100; 
}

void draw() {
  background(0); 
  distanciaX = mouseX - posX;
  distanciaY = mouseY - posY;
  velocidadX = distanciaX / divisor;
  velocidadY = distanciaY / divisor;
  posX = posX + velocidadX;
  posY = posY + velocidadY;
  fill(255);            
  noStroke();        
  ellipse(posX, posY, diametroPelota, diametroPelota);
}

