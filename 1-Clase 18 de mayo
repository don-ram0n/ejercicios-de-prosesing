float posX, posY;      
float angulo;          
float distancia; 
float diametroPelota; 

void setup() {
  size(800, 800);      
  angulo = 0;         
  distancia = 100;      
  diametroPelota = 50;  
  colorMode(HSB, 255);
  background(0);        
  noStroke();          
}

void draw() {
  translate(width / 2, height / 2);
  angulo = angulo + (PI / 30);
  distancia = distancia + 0.1;
  posX = cos(angulo) * distancia;
  posY = sin(angulo) * distancia;
  fill(frameCount % 255, 255, 255);
  ellipse(posX, posY, diametroPelota, diametroPelota);
}

