int posX, posY;          
int dx, dy;              
int diametroPelota;       
int radioPelota;         

void setup() {
  size(800, 800);       
  posX = width / 2;
  posY = height / 2;
  diametroPelota = 100;
  radioPelota = diametroPelota / 2;
}

void draw() {
  background(0, 100, 200);
  if (mousePressed) {
    float distanciaAlCentro = dist(posX, posY, pmouseX, pmouseY);
    if (distanciaAlCentro < radioPelota) {
      dx = mouseX - pmouseX;
      dy = mouseY - pmouseY;
      posX = posX + dx;
      posY = posY + dy;
    }
  }
  fill(255);        
  noStroke();            
  ellipse(posX, posY, diametroPelota, diametroPelota);
}
