PVector pos, vel;
float radio = 50;

void setup() {
  size(800, 600);
  pos = new PVector(width/2, height/2);
  vel = new PVector(2, -1);
}

void draw() {
  background(255);

  pos.add(vel);

  if (pos.x + radio > width || pos.x - radio < 0) {
    vel.x *= -1;
  }

  if (pos.y + radio > height || pos.y - radio < 0) {
    vel.y *= -1;
  }

  ellipse(pos.x, pos.y, radio * 2, radio * 2);
}
